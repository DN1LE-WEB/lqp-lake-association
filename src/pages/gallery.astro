---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getDB } from '../lib/db';

const db = getDB(Astro);
const { results: albums } = await db.prepare(
  "SELECT * FROM gallery_albums WHERE visible = 1 ORDER BY sort_order"
).all();

// Get photos for each album
const albumsWithPhotos = await Promise.all(albums.map(async (album: any) => {
  const { results: photos } = await db.prepare(
    "SELECT * FROM gallery_photos WHERE album_id = ? ORDER BY sort_order"
  ).bind(album.id).all();
  return { ...album, photos };
}));

// Flatten all photos for the masonry layout if only one album,
// or group by album if multiple
const hasMultipleAlbums = albumsWithPhotos.filter((a: any) => a.photos.length > 0).length > 1;
---

<BaseLayout title="Photo Gallery">
  <PageHeader title="Photo Gallery" subtitle="Scenes from Lac Qui Parle Lake and our community events." />

  <section class="mx-auto max-w-[1100px] px-6 pb-10 lg:px-12">
    {hasMultipleAlbums ? (
      albumsWithPhotos.filter((album: any) => album.photos.length > 0).map((album: any) => (
        <div class="mb-10">
          <h2 class="font-display font-bold text-navy text-xl mb-1">{album.title}</h2>
          {album.description && (
            <p class="text-sm text-prairie mb-4">{album.description}</p>
          )}
          <div class="columns-2 gap-3.5 sm:columns-3 lg:columns-4">
            {album.photos.map((photo: any) => (
              <div class="mb-3.5 break-inside-avoid overflow-hidden rounded-[10px] border border-teal-border">
                <img
                  src={photo.url}
                  alt={photo.caption || album.title}
                  class="w-full object-cover transition-transform duration-300 hover:scale-105"
                  loading="lazy"
                />
                {photo.caption && (
                  <div class="px-2 py-1.5 text-xs text-prairie bg-white">{photo.caption}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))
    ) : (
      <div class="columns-2 gap-3.5 sm:columns-3 lg:columns-4">
        {albumsWithPhotos.flatMap((album: any) => album.photos).map((photo: any) => (
          <div class="mb-3.5 break-inside-avoid overflow-hidden rounded-[10px] border border-teal-border">
            <img
              src={photo.url}
              alt={photo.caption || 'Gallery photo'}
              class="w-full object-cover transition-transform duration-300 hover:scale-105"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    )}

    {albumsWithPhotos.every((a: any) => a.photos.length === 0) && (
      <div class="text-center py-12 text-prairie">
        <p>No photos available yet. Check back soon!</p>
      </div>
    )}
  </section>

  <div class="mt-10 text-center pb-10">
    <p class="text-sm text-prairie">
      More photos on our <a href="https://www.facebook.com/lqplakeassociation/" target="_blank" class="font-medium text-teal hover:text-[#1a1a1a]">Facebook page</a>.
    </p>
  </div>

</BaseLayout>
