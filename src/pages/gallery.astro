---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

let galleries: any[] = [];
try {
  const dir = path.join(process.cwd(), 'src/content/gallery');
  if (fs.existsSync(dir)) {
    const files = fs.readdirSync(dir).filter(f => f.endsWith('.json'));
    galleries = files.map(f => ({
      slug: f.replace('.json', ''),
      ...JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')),
    }));
    galleries.sort((a, b) => (b.date || '').localeCompare(a.date || ''));
  }
} catch {}

const categories = ['all', 'fishing', 'tournament', 'lake-views', 'events', 'wildlife', 'projects'];
---

<BaseLayout title="Photo Gallery" description="Photos from Lac Qui Parle Lake - fishing, tournaments, wildlife, and more.">
  <section class="bg-lake-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-4xl font-bold text-white sm:text-5xl">Photo Gallery</h1>
      <p class="mt-4 max-w-2xl text-lg text-lake-200">Scenes from Lac Qui Parle Lake and our community events.</p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {galleries.length > 0 ? (
        <div>
          <!-- Category Filter -->
          <div class="mb-12 flex flex-wrap gap-2" id="gallery-filters">
            {categories.map(cat => (
              <button
                data-category={cat}
                class:list={[
                  'rounded-full px-4 py-2 text-sm font-medium transition-colors',
                  cat === 'all'
                    ? 'bg-lake-700 text-white'
                    : 'bg-lake-100 text-lake-600 hover:bg-lake-200',
                ]}
              >
                {cat === 'all' ? 'All' : cat.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ')}
              </button>
            ))}
          </div>

          <!-- Gallery Grid -->
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="gallery-grid">
            {galleries.map(gallery => (
              <div class="card gallery-item" data-category={gallery.category}>
                <h3 class="mb-3 font-display text-lg font-bold text-lake-900">{gallery.title}</h3>
                {gallery.description && <p class="mb-4 text-sm text-lake-600">{gallery.description}</p>}
                {gallery.images && gallery.images.length > 0 && (
                  <div class="grid grid-cols-2 gap-2">
                    {gallery.images.slice(0, 4).map((img: any, i: number) => (
                      <div class:list={['overflow-hidden rounded-lg', i === 0 && gallery.images.length > 2 ? 'col-span-2' : '']}>
                        <img
                          src={img.image}
                          alt={img.caption || gallery.title}
                          class="aspect-video w-full object-cover transition-transform duration-300 hover:scale-105"
                          loading="lazy"
                        />
                      </div>
                    ))}
                  </div>
                )}
                {gallery.date && <p class="mt-3 text-xs text-lake-400">{gallery.date}</p>}
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-lake-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-lake-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
            </svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-lake-900">Gallery Coming Soon</h2>
          <p class="mt-3 text-lake-600">
            Photos from fishing tournaments, lake events, and the natural beauty of Lac Qui Parle Lake will be added here.
            Check back soon or visit our <a href="https://www.facebook.com/lqplakeassociation/" target="_blank" class="font-medium text-lake-700 hover:text-lake-900">Facebook page</a> for the latest photos.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('#gallery-filters button');
  const items = document.querySelectorAll('.gallery-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');
      buttons.forEach(b => {
        b.classList.remove('bg-lake-700', 'text-white');
        b.classList.add('bg-lake-100', 'text-lake-600');
      });
      btn.classList.remove('bg-lake-100', 'text-lake-600');
      btn.classList.add('bg-lake-700', 'text-white');

      items.forEach(item => {
        if (cat === 'all' || item.getAttribute('data-category') === cat) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
