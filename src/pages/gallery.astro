---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const photos = [
  { src: '/images/original/7332574_orig.jpg', alt: 'Walleye catch' },
  { src: '/images/original/4432214_orig.jpg', alt: 'Fishing on the lake' },
  { src: '/images/original/2201075_orig.jpg', alt: 'Walleye stocking' },
  { src: '/images/original/3946451_orig.jpg', alt: 'Lake fishing' },
  { src: '/images/original/3848027_orig.jpg', alt: 'Walleye' },
  { src: '/images/original/9830291_orig.jpg', alt: 'On the water' },
  { src: '/images/original/9017893.jpg', alt: 'Fish catch' },
  { src: '/images/original/3489574.jpg', alt: 'Fishing day' },
  { src: '/images/original/8751468.jpg', alt: 'Lake scene' },
  { src: '/images/original/8220424.jpg', alt: 'Walleye fishing' },
  { src: '/images/original/5632435.jpg', alt: 'Lake life' },
  { src: '/images/original/3067261.jpg', alt: 'Catch of the day' },
  { src: '/images/original/2610052.jpg', alt: 'Fishing tournament' },
  { src: '/images/original/5212197.jpg', alt: 'Weigh-in' },
  { src: '/images/original/8077812.jpg', alt: 'Lake activity' },
  { src: '/images/original/2162438.jpg', alt: 'Fish' },
  { src: '/images/original/5531282.jpg', alt: 'On the lake' },
  { src: '/images/original/3320413067264908347_orig.jpg', alt: 'Walleye stocking event' },
];
---

<BaseLayout title="Photo Gallery">
  <PageHeader title="Photo Gallery" subtitle="Scenes from Lac Qui Parle Lake and our community events." />

  <section class="mx-auto max-w-[1100px] px-6 pb-10 lg:px-12">
    <div class="columns-2 gap-3.5 sm:columns-3 lg:columns-4">
      {photos.map(photo => (
        <div class="mb-3.5 break-inside-avoid overflow-hidden rounded-[10px] border border-sage-pale">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full object-cover transition-transform duration-300 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </section>

  <div class="mt-10 text-center pb-10">
    <p class="text-sm text-stone">
      More photos on our <a href="https://www.facebook.com/lqplakeassociation/" target="_blank" class="font-medium text-sage hover:text-bark">Facebook page</a>.
    </p>
  </div>

  <div class="blend-sage-to-dark" style="height: 120px;"></div>
</BaseLayout>
