---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Walleye Tournament">
  <PageHeader title="Lac Qui Parle Walleye Tournament" />

  <section class="mx-auto max-w-[1000px] px-6 pb-10 lg:px-12">
    <!-- Current Tournament -->
    <div class="rounded-[14px] border border-sage/10 bg-white p-8">
      <div class="section-tag">Upcoming</div>
      <h2 class="font-display text-2xl font-bold text-[#1a1a1a]">46th Annual Lac Qui Parle Lake Walleye Tournament</h2>
      <p class="mt-2 text-lg font-semibold text-sage">Saturday, June 6th, 2026</p>
      <p class="mt-4 text-[15px] leading-[1.85] text-prairie">All Tournament Information is updated late March 2026.</p>
      <p class="mt-3 text-[15px] text-prairie">2026 Tournament Information — Click on links below to download a printable version:</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/downloads/cover_letter_2026.docx" class="rounded-[10px] border border-sage-pale bg-white/50 px-5 py-2.5 text-sm font-semibold text-[#1a1a1a] transition-colors hover:bg-white">Cover Letter</a>
        <a href="/downloads/tournament_rules_2026.docx" class="rounded-[10px] border border-sage-pale bg-white/50 px-5 py-2.5 text-sm font-semibold text-[#1a1a1a] transition-colors hover:bg-white">Tournament Rules</a>
        <a href="/downloads/2026_release_of_liability.docx" class="rounded-[10px] border border-sage-pale bg-white/50 px-5 py-2.5 text-sm font-semibold text-[#1a1a1a] transition-colors hover:bg-white">Release of Liability</a>
        <a href="/downloads/lqp_membership_application_single.pdf" class="rounded-[10px] border border-sage-pale bg-white/50 px-5 py-2.5 text-sm font-semibold text-[#1a1a1a] transition-colors hover:bg-white">Membership Application</a>
      </div>
    </div>
  </section>


  <!-- Past Tournaments -->
  <section class="bg-white px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-[1000px]">
      <div class="section-tag">Tournament History</div>
      <h2 class="section-heading mb-8">Past Tournaments</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { label: '45th Annual (2025)', href: '#' },
          { label: '44th Annual (2024)', href: '#' },
          { label: '43rd Annual (2023)', href: '#' },
          { label: '42nd Annual (2022)', href: '#' },
          { label: '41st Annual (2021)', href: '#' },
          { label: '41st Annual (2020)', href: '#' },
          { label: '40th Annual (2019)', href: '#' },
          { label: '39th Annual (2018)', href: '#' },
          { label: '38th Annual (2017)', href: '#' },
          { label: '37th Annual (2016)', href: '#' },
          { label: '36th Annual (2015)', href: '#' },
          { label: '35th Annual (2014)', href: '#' },
          { label: '34th Annual (2013)', href: '#' },
          { label: '33rd Annual (2012)', href: '#' },
        ].map(t => (
          <div class="rounded-[10px] border border-sage/10 bg-white px-5 py-4">
            <span class="font-display text-[15px] font-bold text-[#1a1a1a]">{t.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
