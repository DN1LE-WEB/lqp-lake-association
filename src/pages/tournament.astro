---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getDB } from '../lib/db';

const db = getDB(Astro);
const { results: tournaments } = await db.prepare(
  "SELECT id, title, year, date, content, results_url FROM tournaments WHERE visible = 1 ORDER BY year DESC"
).all();

const featured = tournaments.length > 0 ? tournaments[0] : null;
const past = tournaments.slice(1);

let featuredDocs: any[] = [];
if (featured) {
  const { results } = await db.prepare(
    "SELECT * FROM tournament_documents WHERE tournament_id = ? ORDER BY sort_order"
  ).bind(featured.id).all();
  featuredDocs = results || [];
}

function getPreview(content: string | null): string {
  if (!content || content === '{}' || content === '""') return '';
  try {
    const parsed = JSON.parse(content);
    if (parsed.type === 'text' && typeof parsed.content === 'string') {
      content = parsed.content;
    } else if (parsed.type === 'doc' && Array.isArray(parsed.content)) {
      const extractText = (nodes: any[]): string => {
        return nodes.map((n: any) => {
          if (n.type === 'text') return n.text || '';
          if (n.content) return extractText(n.content);
          return '';
        }).join(' ');
      };
      content = extractText(parsed.content).trim();
      if (!content) return '';
    } else if (typeof parsed === 'string') content = parsed;
    else return '';
  } catch {}
  const plain = content
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
    .replace(/[#*_~`{}]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
  if (!plain) return '';
  return plain.length > 150 ? plain.substring(0, 150) + '...' : plain;
}
---

<BaseLayout title="Walleye Tournament">
  <PageHeader title="Lac Qui Parle Walleye Tournament" />

  <section class="mx-auto max-w-[1000px] px-6 pb-10 lg:px-12">
    {featured ? (
      <>
        <a href={`/tournament/${featured.year}`} class="block rounded-[14px] border border-teal-border/10 bg-white p-8 transition-shadow hover:shadow-lg">
          <div class="section-tag">Upcoming</div>
          <h2 class="font-display text-2xl font-bold text-[#1a1a1a]">{featured.title}</h2>
          {featured.date && (
            <p class="mt-2 text-lg font-semibold text-teal">
              {new Date(featured.date as string + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}
            </p>
          )}
          {featured.content && (
            <p class="mt-3 text-prairie leading-relaxed">{getPreview(featured.content as string)}</p>
          )}
          <span class="mt-4 inline-block text-sm font-semibold text-teal">View details &rarr;</span>
        </a>
        {featuredDocs.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {featuredDocs.map((doc: any) => (
              <a
                href={doc.url}
                target="_blank"
                class="inline-flex items-center gap-2 rounded-lg border border-teal-border/20 bg-white px-4 py-2 text-sm font-medium text-[#1a1a1a] transition-colors hover:border-teal hover:text-teal"
              >
                <span class="inline-flex items-center justify-center rounded bg-teal/10 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-teal">{doc.file_type}</span>
                {doc.title}
              </a>
            ))}
          </div>
        )}
      </>
    ) : (
      <div class="rounded-[14px] border border-teal-border/10 bg-white p-8 text-center text-gray-500">
        No upcoming tournament information available.
      </div>
    )}
  </section>

  {past.length > 0 && (
    <section class="bg-white px-6 py-16 lg:px-12">
      <div class="mx-auto max-w-[1000px]">
        <div class="section-tag">Tournament History</div>
        <h2 class="section-heading mb-8">Past Tournaments</h2>
        <div class="space-y-4">
          {past.map((t: any) => (
            <a href={`/tournament/${t.year}`} class="block rounded-[14px] border border-teal-border/10 bg-white px-6 py-5 transition-shadow hover:shadow-lg">
              <div class="flex items-center justify-between">
                <div>
                  <span class="font-display text-lg font-bold text-[#1a1a1a]">
                    {t.title}
                  </span>
                  {t.date && (
                    <span class="ml-3 text-sm text-prairie">
                      {new Date(t.date as string + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                    </span>
                  )}
                </div>
                <span class="text-sm font-semibold text-teal">&rarr;</span>
              </div>
              {t.content && (
                <p class="mt-2 text-sm text-prairie leading-relaxed">{getPreview(t.content as string)}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
