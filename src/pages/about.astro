---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getDB } from '../lib/db';
import { renderContent } from '../lib/render-content';

const db = getDB(Astro);
const page = await db.prepare("SELECT * FROM pages WHERE slug = 'about'").first();
const html = page ? renderContent(page.content as string) : '';
---

<BaseLayout title={page?.title as string || 'Our Mission'}>
  <PageHeader title={page?.title as string || 'Our Mission'} />

  <section class="mx-auto max-w-[700px] px-6 pb-20 lg:px-12">
    <div class="prose-prairie" set:html={html} />
  </section>

</BaseLayout>
