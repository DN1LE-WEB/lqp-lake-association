---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Our Mission">
  <PageHeader title="Our Mission" />

  <section class="mx-auto max-w-[700px] px-6 pb-20 lg:px-12">
    <div class="prose-prairie">
      <p>To advocate the need for soil and water conservation in the watershed. To raise public awareness of environmental issues that have an impact on the lake and to generate response to promote the sport and recreational opportunities of the Lac Qui Parle Lake Area.</p>
    </div>
  </section>

  <div class="blend-sage-to-dark"></div>
</BaseLayout>
