---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Fishing League">
  <PageHeader title="LQP Fishing League" />

  <section class="mx-auto max-w-[1000px] px-6 pb-10 lg:px-12">
    <div class="rounded-[14px] border border-sage/10 bg-white p-8">
      <div class="section-tag">Current Season</div>
      <h2 class="font-display text-2xl font-bold text-bark-deep">2026 Lac Qui Parle Walleye League</h2>

      <div class="mt-6">
        <h3 class="mb-4 font-display text-lg font-bold text-bark">2026 Roster &amp; Weekly Results</h3>
        <div class="grid gap-2.5 sm:grid-cols-2 lg:grid-cols-3">
          {['Week #1 Results', 'Week #2 Results', 'Week #3 Results', 'Week #4 Results', 'Week #5 Results', 'Week #6 Results', 'End of the Year Results'].map(week => (
            <div class="flex items-center justify-between rounded-[10px] border border-sage-pale bg-linen px-4 py-3">
              <span class="text-sm font-medium text-bark">{week}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-6">
        <a
          href="https://docs.google.com/spreadsheets/d/1EUozTvo7sJOHElyerPSpSfOPyTikDXBZgNaomz8-MhY/edit?gid=0#gid=0"
          target="_blank"
          class="inline-block rounded-[10px] border border-sage-pale bg-sage-pale/50 px-5 py-2.5 text-sm font-semibold text-bark transition-colors hover:bg-sage-pale"
        >
          2026 Lac Qui Parle Lake Walleye League Results
        </a>
      </div>
    </div>
  </section>

  <div class="blend-linen-to-sage"></div>

  <section class="bg-sage-pale px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-[1000px]">
      <div class="section-tag">Past Seasons</div>
      <h2 class="section-heading mb-8">League History</h2>
      <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-4">
        {[2025, 2024, 2023, 2022, 2021, 2020, 2019, 2018, 2017, 2016, 2015, 2014, 2013].map(year => (
          <div class="rounded-[10px] border border-sage/10 bg-white px-5 py-4">
            <span class="font-display text-[15px] font-bold text-bark">LQP Fishing League {year}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="blend-sage-to-dark"></div>
</BaseLayout>
