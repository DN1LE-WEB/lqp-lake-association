---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

let seasons: any[] = [];
try {
  const dir = path.join(process.cwd(), 'src/content/fishing-league');
  if (fs.existsSync(dir)) {
    const files = fs.readdirSync(dir).filter(f => f.endsWith('.json'));
    seasons = files.map(f => ({
      slug: f.replace('.json', ''),
      ...JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')),
    }));
    seasons.sort((a, b) => (b.year || 0) - (a.year || 0));
  }
} catch {}
const current = seasons[0];
const past = seasons.slice(1);
---

<BaseLayout title="Fishing League" description="LQP Fishing League - weekly walleye fishing competition on Lac Qui Parle Lake.">
  <section class="bg-lake-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-4xl font-bold text-white sm:text-5xl">LQP Fishing League</h1>
      <p class="mt-4 max-w-2xl text-lg text-lake-200">Weekly walleye competition throughout the summer season.</p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {current ? (
        <div class="mb-16">
          <div class="card border-t-4 border-t-forest-500">
            <div class="mb-2 inline-flex items-center rounded-full bg-forest-100 px-3 py-1 text-sm font-medium text-forest-700">
              Current Season
            </div>
            <h2 class="mt-2 font-display text-2xl font-bold text-lake-900">
              {current.year} Lac Qui Parle Walleye League
            </h2>
            {current.resultsUrl && (
              <a href={current.resultsUrl} target="_blank" class="btn-primary mt-6">
                View Full Results Spreadsheet
              </a>
            )}
            {current.weeks && current.weeks.length > 0 && (
              <div class="mt-8">
                <h3 class="mb-4 font-display text-lg font-bold text-lake-800">Weekly Results</h3>
                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                  {current.weeks.map((w: any) => (
                    <div class="flex items-center justify-between rounded-xl border border-lake-100 bg-lake-50 px-4 py-3">
                      <span class="text-sm font-medium text-lake-700">{w.label || `Week #${w.weekNumber}`}</span>
                      {w.resultsUrl ? (
                        <a href={w.resultsUrl} target="_blank" class="text-sm font-semibold text-lake-600 hover:text-lake-800">View</a>
                      ) : (
                        <span class="text-xs text-lake-400">Pending</span>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ) : (
        <div class="mb-16 card border-t-4 border-t-forest-500">
          <div class="mb-2 inline-flex items-center rounded-full bg-forest-100 px-3 py-1 text-sm font-medium text-forest-700">
            Current Season
          </div>
          <h2 class="mt-2 font-display text-2xl font-bold text-lake-900">2026 Lac Qui Parle Walleye League</h2>
          <p class="mt-4 text-lake-600">Season results will be posted as weeks are completed.</p>
          <a href="https://docs.google.com/spreadsheets/d/1EUozTvo7sJOHElyerPSpSfOPyTikDXBZgNaomz8-MhY/edit?gid=0#gid=0" target="_blank" class="btn-primary mt-6">
            View 2026 Results Spreadsheet
          </a>
        </div>
      )}

      <div>
        <h2 class="section-heading mb-8">Past Seasons</h2>
        {past.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {past.map(s => (
              <div class="card">
                <h3 class="font-display text-lg font-bold text-lake-900">{s.year} Season</h3>
                {s.resultsUrl && (
                  <a href={s.resultsUrl} target="_blank" class="mt-2 inline-block text-sm font-medium text-lake-600 hover:text-lake-800">
                    View Results &rarr;
                  </a>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {[2025, 2024, 2023, 2022, 2021, 2020, 2019, 2018, 2017, 2016, 2015, 2014, 2013].map(year => (
              <div class="card">
                <h3 class="font-display text-lg font-bold text-lake-900">{year} Season</h3>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
