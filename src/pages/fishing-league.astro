---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getDB } from '../lib/db';

const db = getDB(Astro);
const { results: seasons } = await db.prepare(
  "SELECT id, title, year, content, results_url FROM fishing_league WHERE visible = 1 ORDER BY year DESC"
).all();

const current = seasons.length > 0 ? seasons[0] : null;
const past = seasons.slice(1);

function getPreview(content: string | null): string {
  if (!content) return '';
  // Strip markdown formatting for preview
  const plain = content
    .replace(/!\[.*?\]\(.*?\)/g, '')  // images
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')  // links
    .replace(/[#*_~`]/g, '')  // formatting chars
    .replace(/\n+/g, ' ')  // newlines
    .trim();
  return plain.length > 150 ? plain.substring(0, 150) + '...' : plain;
}
---

<BaseLayout title="Fishing League">
  <PageHeader title="LQP Fishing League" />

  <section class="mx-auto max-w-[1000px] px-6 pb-10 lg:px-12">
    {current ? (
      <a href={`/league/${current.year}`} class="block rounded-[14px] border border-teal-border/10 bg-white p-8 transition-shadow hover:shadow-lg">
        <div class="section-tag">Current Season</div>
        <h2 class="font-display text-2xl font-bold text-[#1a1a1a]">{current.title}</h2>
        {current.content && (
          <p class="mt-3 text-prairie leading-relaxed">{getPreview(current.content as string)}</p>
        )}
        <span class="mt-4 inline-block text-sm font-semibold text-teal">View details &rarr;</span>
      </a>
    ) : (
      <div class="rounded-[14px] border border-teal-border/10 bg-white p-8 text-center text-gray-500">
        No current season information available.
      </div>
    )}
  </section>

  {past.length > 0 && (
    <section class="bg-white px-6 py-16 lg:px-12">
      <div class="mx-auto max-w-[1000px]">
        <div class="section-tag">Past Seasons</div>
        <h2 class="section-heading mb-8">League History</h2>
        <div class="space-y-4">
          {past.map((s: any) => (
            <a href={`/league/${s.year}`} class="block rounded-[14px] border border-teal-border/10 bg-white px-6 py-5 transition-shadow hover:shadow-lg">
              <div class="flex items-center justify-between">
                <span class="font-display text-lg font-bold text-[#1a1a1a]">{s.title}</span>
                <span class="text-sm font-semibold text-teal">&rarr;</span>
              </div>
              {s.content && (
                <p class="mt-2 text-sm text-prairie leading-relaxed">{getPreview(s.content as string)}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
