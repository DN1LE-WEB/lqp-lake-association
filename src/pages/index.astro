---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDB } from '../lib/db';
import { renderContent } from '../lib/render-content';

const db = getDB(Astro);
const { results: newsItems } = await db.prepare(
  "SELECT * FROM news WHERE visible = 1 ORDER BY sort_order, created_at DESC"
).all();
---

<BaseLayout title="Home">
  <!-- HERO -->
  <section style="background: #0F1B2D;" class="pt-[120px]">
    <div class="mx-auto max-w-[1100px] px-6 pb-10 lg:px-12">
      <div class="flex items-center gap-[6px] text-[10px] font-semibold uppercase tracking-[2.5px] text-teal-light mb-4">
        Est. 1982 <span class="inline-block h-[3px] w-[3px] rounded-full bg-teal-light/50"></span> Montevideo, Minnesota <span class="inline-block h-[3px] w-[3px] rounded-full bg-teal-light/50"></span> Non-Profit
      </div>
      <h1 class="font-display text-[42px] font-bold leading-[1.15] text-white sm:text-[50px]">
        Welcome to The<br /><em class="font-normal italic text-teal-light">Lac Qui Parle</em><br />Lake Association
      </h1>
    </div>
    <img
      src="/images/original/header-1382410480.jpg"
      alt="Lac Qui Parle Lake at the bridge - Photo by Bret Amundson"
      class="w-full"
    />
  </section>

  <!-- WELCOME -->
  <section class="mx-auto max-w-[1000px] px-6 py-16 lg:px-12">
    <div class="grid items-start gap-16 lg:grid-cols-[1.1fr_1fr]">
      <div>
        <div class="section-tag">About the Association</div>
        <h2 class="section-heading mb-5">Welcome to The Lac Qui Parle Lake Association</h2>
        <p class="mb-3.5 text-[15px] leading-[1.85] text-prairie">Walleye and waterfowl are two things that come to mind when outdoorsman around Minnesota hear the words Lac Qui Parle Lake. Lac Qui Parle has a tradition of being one of the best walleye fisheries in the state and the Lac Qui Parle Lake Association is helping in keeping that tradition alive for the anglers of Minnesota.</p>
        <p class="text-[15px] leading-[1.85] text-prairie">The Lac Qui Parle Lake Association was created in 1982 as a non-profit organization. Since its inception, the Lac Qui Parle Lake Association has been involved in funding numerous lake projects as well as projects that help aid the outdoor enthusiast. The Lac Qui Parle Lake Association works in conjunction with the Minnesota DNR and has been instrumental in providing funding for walleye stocking programs, fishing piers, boat ramps and rip rap projects on the erodible shorelines of Lac Qui Parle Lake.</p>
      </div>
      <div>
        <div class="rounded-[14px] border border-teal-border bg-teal-pale p-7">
          <h3 class="mb-2.5 font-display text-base font-bold text-teal">Board of Directors</h3>
          <p class="text-sm leading-8 text-prairie-dark">Scott Monson, Steve Mitlyng,<br />Joe Bungarden, Pete McGinty<br />Andy Johnson, Brett Jacobs and Gary Groothius</p>
        </div>
        <img src="/images/original/4608857.jpg" alt="Lac Qui Parle Lake Association" class="mt-4 rounded-[10px]" />
      </div>
    </div>
  </section>

  <hr class="mx-auto max-w-[1000px] border-teal-border" />

  <!-- Announcements -->
  <section class="mx-auto max-w-[1000px] px-6 py-16 lg:px-12">
    <div class="section-tag mb-6">Recent News</div>

    {newsItems.length === 0 && (
      <p class="text-sm text-prairie">No news at this time.</p>
    )}

    {newsItems.map((item: any, idx: number) => (
      <div class:list={[
        "grid items-center gap-7 rounded-[14px] border border-teal-border bg-white p-8",
        item.image_url ? "sm:grid-cols-[200px_1fr]" : "",
        idx < newsItems.length - 1 ? "mb-4" : "",
      ]}>
        {item.image_url && (
          <img src={item.image_url} alt={item.title} class="h-[150px] w-full rounded-[10px] object-cover" />
        )}
        <div>
          <h3 class="mb-2 font-display text-lg font-bold">{item.title}</h3>
          <div class="text-sm leading-[1.75] text-prairie prose prose-sm max-w-none" set:html={renderContent(item.content as string)} />
        </div>
      </div>
    ))}
  </section>

  <hr class="mx-auto max-w-[1000px] border-teal-border" />

  <!-- Features -->
  <section class="mx-auto max-w-[1000px] px-6 py-16 lg:px-12">
    <div class="section-tag">What We Do</div>
    <h2 class="section-heading mb-10">Lake Projects &amp; Events</h2>

    <div class="mb-3.5 grid gap-3.5 sm:grid-cols-2">
      <a href="/tournament" class="card block p-8">
        <div class="section-tag">Annual Event</div>
        <h3 class="font-display text-xl font-bold">Lac Qui Parle Walleye Tournament</h3>
        <div class="mb-2.5 text-[13px] font-semibold text-teal">46th Annual &middot; Saturday, June 6th, 2026</div>
        <p class="text-sm leading-[1.7] text-prairie">All Tournament Information is updated late March 2026. Download cover letters, tournament rules, and liability waivers from the tournament page.</p>
      </a>
      <a href="/fishing-league" class="card block p-8">
        <div class="section-tag">Summer Season</div>
        <h3 class="font-display text-xl font-bold">LQP Fishing League</h3>
        <div class="mb-2.5 text-[13px] font-semibold text-teal">2026 Lac Qui Parle Walleye League</div>
        <p class="text-sm leading-[1.7] text-prairie">Weekly walleye league competition throughout the summer season with roster, weekly results, and end of year standings.</p>
      </a>
    </div>

    <a href="/projects" class="card block p-8">
      <div class="grid gap-8 sm:grid-cols-2">
        <div>
          <div class="section-tag">Conservation &amp; Community</div>
          <h3 class="mb-2 font-display text-xl font-bold">Lake Association Projects</h3>
          <p class="text-sm leading-[1.7] text-prairie">Walleye stocking programs, fishing pier construction, boat ramp improvements, rip rap projects on erodible shorelines, youth fishing activities, and community partnerships.</p>
        </div>
        <div>
          <p class="mt-0 text-sm leading-[1.7] text-prairie sm:mt-[26px]">Includes the LQP Lake "Dam Cam," youth activities programs, and ongoing partnerships with the Minnesota DNR for lake improvement and conservation.</p>
        </div>
      </div>
    </a>
  </section>

  <!-- Stocking & Membership -->
  <section style="background: #0F1B2D;" class="px-6 py-16 lg:px-12">
    <div class="mx-auto grid max-w-[1000px] items-start gap-16 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <div class="section-tag" style="color: #6BB8A5;">Fin-Clipped Walleyes</div>
        <h2 class="mb-5 font-display text-[28px] font-bold leading-snug text-white/90">We would like all those fishing Lac Qui Parle Lake to keep an eye out for fin clipped walleyes being caught.</h2>
        <p class="mb-3.5 text-[15px] leading-[1.85] text-white/50">If they have a fin clipped on the bottom left of the fish, they were stocked as a young of the year fish. Please let us know if you catch any of these fish, by emailing <a href="mailto:minnkotatackle@yahoo.com" class="text-teal-light no-underline">minnkotatackle@yahoo.com</a>.</p>
        <p class="mt-6 text-sm leading-[1.85] text-white/60">Become a LQP Lake Association Member! The Lac Qui Parle Lake Association is a non-profit organization located out of Montevideo, MN that strives for the betterment of Lac Qui Parle Lake. Donations are accepted and greatly appreciated to aid in making Lac Qui Parle Lake a better place for you and future generations to enjoy. Yearly dues are $10.00.</p>
      </div>
      <div class="mt-3 rounded-[14px] border border-white/[0.06] bg-white/[0.04] p-9 text-center">
        <div class="font-display text-[52px] font-bold text-teal-light">$10</div>
        <div class="mt-1 text-[11px] uppercase tracking-[2.5px] text-white/60">Yearly Dues</div>
        <div class="mx-auto my-5 h-px w-10 bg-white/10"></div>
        <div class="text-[13px] leading-[1.8] text-white/60">
          LQP Lake Association<br />
          PO Box 66<br />Montevideo, MN 56265<br /><br />
          <a href="mailto:minnkotatackle@yahoo.com" class="text-teal-light no-underline">minnkotatackle@yahoo.com</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
