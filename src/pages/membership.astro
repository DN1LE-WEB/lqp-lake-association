---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Membership" description="Join the Lac Qui Parle Lake Association - yearly dues are just $10.">
  <section class="bg-lake-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-4xl font-bold text-white sm:text-5xl">Become a Member</h1>
      <p class="mt-4 max-w-2xl text-lg text-lake-200">Support Lac Qui Parle Lake for just $10 per year.</p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Membership Info -->
        <div>
          <h2 class="section-heading">Join the LQP Lake Association</h2>
          <div class="mt-6 space-y-4 text-base leading-relaxed text-lake-700">
            <p>
              The Lac Qui Parle Lake Association is a non-profit organization located out of Montevideo, MN that strives for the betterment of Lac Qui Parle Lake. Donations are accepted and greatly appreciated to aid in making Lac Qui Parle Lake a better place for you and future generations to enjoy.
            </p>
          </div>

          <div class="mt-8 space-y-4">
            <h3 class="font-display text-lg font-bold text-lake-900">Your membership supports:</h3>
            <ul class="space-y-3">
              {[
                'Walleye stocking programs with the MN DNR',
                'Fishing pier construction and maintenance',
                'Boat ramp improvements',
                'Shoreline erosion protection (rip rap)',
                'Youth fishing activities and education',
                'Annual walleye tournament operations',
                'Community partnerships',
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-forest-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-lake-700">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Membership Card -->
        <div>
          <div class="overflow-hidden rounded-3xl bg-gradient-to-br from-lake-700 to-lake-900 p-8 text-white shadow-xl sm:p-10">
            <div class="text-center">
              <div class="inline-flex items-center rounded-full bg-white/10 px-4 py-1.5 text-sm text-lake-200">
                Annual Membership
              </div>
              <div class="mt-6">
                <span class="font-display text-6xl font-bold">$10</span>
                <span class="text-xl text-lake-300">/year</span>
              </div>
              <p class="mt-4 text-lake-200">
                Every dollar goes directly toward lake improvement and conservation.
              </p>
            </div>

            <div class="mt-8 space-y-6 border-t border-white/20 pt-8">
              <div>
                <h4 class="mb-2 font-semibold">Mail your membership to:</h4>
                <p class="text-lake-200">
                  LQP Lake Association<br />
                  PO Box 66<br />
                  Montevideo, MN 56265
                </p>
              </div>
              <div>
                <h4 class="mb-2 font-semibold">Questions?</h4>
                <a href="mailto:minnkotatackle@yahoo.com" class="text-lake-200 underline decoration-lake-400 underline-offset-2 transition-colors hover:text-white">
                  minnkotatackle@yahoo.com
                </a>
              </div>
            </div>

            <div class="mt-8">
              <a
                href="/downloads/lqp_membership_application.pdf"
                class="block w-full rounded-xl bg-white py-3.5 text-center font-semibold text-lake-900 shadow-sm transition-all hover:bg-lake-100 hover:shadow-md"
              >
                Download Membership Form (PDF)
              </a>
            </div>
          </div>

          <div class="mt-6 rounded-2xl border border-forest-200 bg-forest-50 p-6">
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-6 w-6 flex-shrink-0 text-forest-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
              <div>
                <h4 class="font-semibold text-forest-900">Donations Welcome</h4>
                <p class="mt-1 text-sm text-forest-700">
                  Additional donations beyond membership dues are greatly appreciated and are tax-deductible. All funds go directly toward lake improvement projects.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
