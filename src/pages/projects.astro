---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Lake Association Projects">
  <PageHeader title="Lake Association Projects" subtitle="Conservation, infrastructure, and community projects funded by the LQP Lake Association." />

  <section class="mx-auto max-w-[1000px] px-6 pb-10 lg:px-12">
    <div class="grid gap-3.5 sm:grid-cols-2">
      <div class="rounded-[14px] border-l-[3px] border-l-sage border border-sage-pale/30 bg-white p-8">
        <h3 class="font-display text-xl font-bold text-bark-deep">Walleye Stocking Program</h3>
        <p class="mt-3 text-sm leading-[1.75] text-stone">Working with the Minnesota DNR, we fund the stocking of walleyes in Lac Qui Parle Lake. Our goal is to stock 25,000 walleyes. Young-of-the-year fish measuring 7-9" are fin-clipped on the bottom left pectoral fin for tracking.</p>
      </div>
      <div class="rounded-[14px] border-l-[3px] border-l-rust border border-sage-pale/30 bg-white p-8">
        <h3 class="font-display text-xl font-bold text-bark-deep">Tri-County Let's Go Fishing</h3>
        <p class="mt-3 text-sm leading-[1.75] text-stone">Lake Association recently donated $12,000 to Tri-County Let's Go Fishing, supporting youth fishing education and community engagement programs.</p>
      </div>
      <div class="rounded-[14px] border-l-[3px] border-l-wheat border border-sage-pale/30 bg-white p-8">
        <h3 class="font-display text-xl font-bold text-bark-deep">Shoreline Protection</h3>
        <p class="mt-3 text-sm leading-[1.75] text-stone">Rip rap projects on the erodible shorelines of Lac Qui Parle Lake help prevent erosion and protect the lake's habitat for fish and wildlife.</p>
      </div>
      <div class="rounded-[14px] border-l-[3px] border-l-sage-light border border-sage-pale/30 bg-white p-8">
        <h3 class="font-display text-xl font-bold text-bark-deep">Infrastructure Improvements</h3>
        <p class="mt-3 text-sm leading-[1.75] text-stone">Funding for fishing piers, boat ramps, and other access improvements that help anglers and outdoor enthusiasts enjoy Lac Qui Parle Lake.</p>
      </div>
    </div>
  </section>

  <div class="blend-linen-to-sage"></div>

  <section class="bg-sage-pale px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-[1000px]">
      <div class="section-tag">Special Projects</div>
      <div class="grid gap-3.5 sm:grid-cols-2">
        <div class="rounded-[14px] border border-sage/10 bg-white p-8">
          <h3 class="font-display text-xl font-bold text-bark-deep">LQP Lake "Dam Cam"</h3>
          <p class="mt-3 text-sm leading-[1.75] text-stone">Check out our Dam Cam for a live view of the Lac Qui Parle Lake dam. Stay updated on water levels and conditions.</p>
        </div>
        <div class="rounded-[14px] border border-sage/10 bg-white p-8">
          <h3 class="font-display text-xl font-bold text-bark-deep">Youth Activities</h3>
          <p class="mt-3 text-sm leading-[1.75] text-stone">The LQP Lake Association supports youth fishing activities and education programs to foster the next generation of anglers and conservationists.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="blend-sage-to-dark"></div>
</BaseLayout>
