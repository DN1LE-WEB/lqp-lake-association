---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDB } from '../../../lib/db';
import NewsEditor from '../../../components/admin/NewsEditor';

const { id } = Astro.params;
const isNew = id === 'new';

let newsItem: any = null;
if (!isNew) {
  const db = getDB(Astro);
  newsItem = await db.prepare("SELECT * FROM news WHERE id = ?").bind(id).first();
  if (!newsItem) {
    return Astro.redirect('/admin/news');
  }
}
---

<AdminLayout title={isNew ? 'New News Item' : `Edit: ${newsItem.title}`}>
  <div class="max-w-4xl">
    <div class="mb-4">
      <a href="/admin/news" class="text-sm text-teal hover:underline">&larr; Back to News</a>
    </div>
    <NewsEditor
      client:only="react"
      id={isNew ? 'new' : String(newsItem.id)}
      title={isNew ? '' : (newsItem.title as string)}
      content={isNew ? '' : (newsItem.content as string)}
      image_url={isNew ? '' : (newsItem.image_url as string || '')}
      visible={isNew ? true : Boolean(newsItem.visible)}
    />
  </div>
</AdminLayout>
