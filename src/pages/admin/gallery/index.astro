---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDB } from '../../../lib/db';

const db = getDB(Astro);
const { results: albums } = await db.prepare(
  `SELECT a.*, COUNT(p.id) as photo_count
   FROM gallery_albums a
   LEFT JOIN gallery_photos p ON p.album_id = a.id
   GROUP BY a.id
   ORDER BY a.sort_order`
).all();
---

<AdminLayout title="Gallery">
  <div class="max-w-4xl">
    <div class="flex items-center justify-between mb-6">
      <p class="text-gray-600">Manage photo albums and gallery images.</p>
      <a
        href="/admin/gallery/new"
        class="inline-flex items-center px-4 py-2 bg-teal text-white text-sm font-medium rounded-lg hover:opacity-90 transition-opacity"
      >
        + Add Album
      </a>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 bg-gray-50">
            <th class="text-left px-4 py-3 font-semibold text-gray-700">Title</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-700">Photos</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-700">Status</th>
            <th class="text-right px-4 py-3 font-semibold text-gray-700">Actions</th>
          </tr>
        </thead>
        <tbody>
          {(albums as any[]).map((album) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 font-medium text-navy">{album.title}</td>
              <td class="px-4 py-3 text-gray-500">{album.photo_count} photos</td>
              <td class="px-4 py-3">
                {album.visible ? (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Visible
                  </span>
                ) : (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                    Hidden
                  </span>
                )}
              </td>
              <td class="px-4 py-3 text-right">
                <a
                  href={`/admin/gallery/${album.id}`}
                  class="inline-flex items-center px-3 py-1.5 bg-teal text-white text-xs font-medium rounded-md hover:opacity-90 transition-opacity"
                >
                  Edit
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {albums.length === 0 && (
        <div class="px-4 py-8 text-center text-gray-400">No albums found. Click "Add Album" to create one.</div>
      )}
    </div>
  </div>
</AdminLayout>
