---
export const prerender = false;
import { verifySession } from '../../lib/auth';

const isLoggedIn = await verifySession(Astro);
if (isLoggedIn) {
  return Astro.redirect('/admin');
}

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Zilla+Slab:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <title>Admin Login | LQP Lake Association</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'DM Sans', sans-serif;
        background: #0F1B2D;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .card {
        background: #162338;
        border: 1px solid rgba(61, 122, 104, 0.2);
        border-radius: 12px;
        padding: 40px 36px;
        width: 100%;
        max-width: 400px;
        margin: 20px;
      }
      .badge {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
      }
      .badge-inner {
        background: rgba(61, 122, 104, 0.15);
        border: 1px solid rgba(61, 122, 104, 0.3);
        border-radius: 8px;
        padding: 10px 18px;
        font-family: 'Zilla Slab', serif;
        font-weight: 700;
        font-size: 14px;
        color: #5DB89A;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      h1 {
        font-family: 'Zilla Slab', serif;
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        text-align: center;
        margin-bottom: 28px;
      }
      .error {
        background: rgba(220, 53, 69, 0.15);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #f87171;
        font-size: 14px;
        padding: 10px 14px;
        border-radius: 8px;
        margin-bottom: 20px;
        text-align: center;
      }
      label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #94a3b8;
        margin-bottom: 6px;
      }
      input[type="password"] {
        width: 100%;
        padding: 12px 14px;
        background: #0F1B2D;
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 8px;
        color: #ffffff;
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
      }
      input[type="password"]:focus {
        border-color: #3D7A68;
      }
      button {
        width: 100%;
        margin-top: 20px;
        padding: 12px;
        background: #3D7A68;
        color: #ffffff;
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s;
      }
      button:hover {
        background: #4a9480;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="badge">
        <span class="badge-inner">LQP Lake</span>
      </div>
      <h1>Admin Login</h1>
      {error && <div class="error">Invalid password. Please try again.</div>}
      <form method="POST" action="/api/auth/login">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter admin password" required />
        <button type="submit">Log In</button>
      </form>
    </div>
  </body>
</html>
