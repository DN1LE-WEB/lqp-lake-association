---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getDB } from '../../lib/db';
import { processMarkdown } from '../../lib/process-markdown';

const { year } = Astro.params;
const yearNum = parseInt(year!, 10);

if (isNaN(yearNum)) {
  return Astro.redirect('/tournament');
}

const db = getDB(Astro);

const tournament = await db.prepare(
  "SELECT * FROM tournaments WHERE year = ? AND visible = 1"
).bind(yearNum).first();

if (!tournament) {
  return Astro.redirect('/tournament');
}

const { results: photos } = await db.prepare(
  "SELECT * FROM tournament_photos WHERE tournament_id = ? ORDER BY sort_order"
).bind(tournament.id).all();

const prevTournament = await db.prepare(
  "SELECT year FROM tournaments WHERE year < ? AND visible = 1 ORDER BY year DESC LIMIT 1"
).bind(yearNum).first();

const nextTournament = await db.prepare(
  "SELECT year FROM tournaments WHERE year > ? AND visible = 1 ORDER BY year ASC LIMIT 1"
).bind(yearNum).first();

const renderedWriteup = await processMarkdown(tournament.writeup as string);

// Limit photo display - show first 30, mention total if more
const displayPhotos = (photos as any[]).slice(0, 30);
const totalPhotos = (photos as any[]).length;
const hasMorePhotos = totalPhotos > 30;
---

<BaseLayout title={tournament.title as string}>
  <PageHeader title={tournament.title as string} subtitle={tournament.date ? new Date((tournament.date as string) + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) : undefined} />

  <section class="mx-auto max-w-[800px] px-6 pb-16 lg:px-12">
    {tournament.results_url && (
      <div class="mb-8">
        <a
          href={tournament.results_url as string}
          target="_blank"
          class="inline-block rounded-[10px] border border-teal-border bg-teal/10 px-5 py-2.5 text-sm font-semibold text-teal transition-colors hover:bg-teal/20"
        >
          View Tournament Results &rarr;
        </a>
      </div>
    )}

    {renderedWriteup && (
      <article
        class="prose prose-base max-w-none
          prose-headings:font-display prose-headings:text-[#1a1a1a]
          prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-3
          prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3 prose-h3:pb-2 prose-h3:border-b prose-h3:border-teal-border/20
          prose-p:text-prairie prose-p:text-[15px] prose-p:leading-[1.85] prose-p:mb-4
          prose-a:text-teal prose-a:no-underline hover:prose-a:underline
          prose-img:rounded-[10px] prose-img:my-6 prose-img:max-w-md prose-img:mx-auto
          prose-strong:text-[#1a1a1a] prose-strong:font-semibold
          prose-ol:pl-6 prose-ol:space-y-0.5
          prose-li:text-prairie prose-li:text-sm"
        set:html={renderedWriteup}
      />
    )}

    {displayPhotos.length > 0 && (
      <div class="mt-12">
        <h3 class="font-display text-lg font-bold text-[#1a1a1a] mb-4 pb-2 border-b border-teal-border/20">
          Tournament Photos {hasMorePhotos && <span class="text-sm font-normal text-prairie">({totalPhotos} total)</span>}
        </h3>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
          {displayPhotos.map((photo: any) => (
            <div class="overflow-hidden rounded-[8px] border border-teal-border/30">
              <img
                src={photo.url}
                alt={photo.caption || 'Tournament photo'}
                class="aspect-square w-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
        {hasMorePhotos && (
          <p class="mt-4 text-center text-sm text-prairie">
            Showing {displayPhotos.length} of {totalPhotos} photos
          </p>
        )}
      </div>
    )}

    <!-- Navigation -->
    <div class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-teal-border/20 pt-6">
      <div>
        {prevTournament && (
          <a href={`/tournament/${prevTournament.year}`} class="text-sm font-semibold text-teal hover:underline">
            &larr; {(prevTournament.year as number)} Tournament
          </a>
        )}
      </div>
      <a href="/tournament" class="text-sm text-prairie hover:underline">
        All Tournaments
      </a>
      <div>
        {nextTournament && (
          <a href={`/tournament/${nextTournament.year}`} class="text-sm font-semibold text-teal hover:underline">
            {(nextTournament.year as number)} Tournament &rarr;
          </a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
