---
const currentYear = new Date().getFullYear();
---

<footer style="background: #0F1B2D;" class="px-6 py-8 lg:px-12">
  <div class="mx-auto flex max-w-[1000px] flex-wrap items-start justify-between gap-8">
    <div>
      <div class="font-display text-sm font-bold text-white/80">Lac Qui Parle Lake Association</div>
      <div class="mt-1 text-xs text-white/50">Non-profit &middot; Est. 1982 &middot; Montevideo, MN</div>
    </div>
    <div class="flex gap-8 text-xs text-white/50">
      <div class="space-y-1">
        <a href="/about" class="block no-underline hover:text-white/60">Our Mission</a>
        <a href="/projects" class="block no-underline hover:text-white/60">Projects</a>
        <a href="/tournament" class="block no-underline hover:text-white/60">Tournament</a>
        <a href="/fishing-league" class="block no-underline hover:text-white/60">Fishing League</a>
      </div>
      <div class="space-y-1">
        <a href="/gallery" class="block no-underline hover:text-white/60">Gallery</a>
        <a href="/membership" class="block no-underline hover:text-white/60">Membership</a>
        <a href="https://www.facebook.com/lqplakeassociation/" target="_blank" rel="noopener" class="block no-underline hover:text-white/60">Facebook</a>
      </div>
    </div>
    <div class="text-xs text-white/50">
      <div>PO Box 66, Montevideo, MN 56265</div>
      <a href="mailto:minnkotatackle@yahoo.com" class="text-sage-light no-underline hover:opacity-80">minnkotatackle@yahoo.com</a>
    </div>
  </div>
  <div class="mx-auto mt-6 max-w-[1000px] border-t border-white/[0.06] pt-4 text-[11px] text-white/50">
    &copy; {currentYear} Lac Qui Parle Lake Association
  </div>
</footer>
