---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-lake-200 bg-lake-950 text-lake-200">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-lake-700 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12c.6.5 1.2 1 2.5 1C7 13 7 11 9.5 11c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
              <path d="M2 17c.6.5 1.2 1 2.5 1C7 18 7 16 9.5 16c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
            </svg>
          </div>
          <div>
            <div class="font-display text-lg font-bold text-white">Lac Qui Parle</div>
            <div class="text-xs font-medium uppercase tracking-wider text-lake-400">Lake Association</div>
          </div>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-lake-300">
          Preserving Minnesota's premier walleye fishery since 1982. A non-profit organization dedicated to the betterment of Lac Qui Parle Lake.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-lake-400">Quick Links</h3>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-sm text-lake-300 transition-colors hover:text-white">Our Mission</a></li>
          <li><a href="/projects" class="text-sm text-lake-300 transition-colors hover:text-white">Lake Projects</a></li>
          <li><a href="/tournament" class="text-sm text-lake-300 transition-colors hover:text-white">Walleye Tournament</a></li>
          <li><a href="/fishing-league" class="text-sm text-lake-300 transition-colors hover:text-white">Fishing League</a></li>
          <li><a href="/membership" class="text-sm text-lake-300 transition-colors hover:text-white">Become a Member</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-lake-400">Contact</h3>
        <ul class="space-y-2.5 text-sm text-lake-300">
          <li>PO Box 66</li>
          <li>Montevideo, MN 56265</li>
          <li>
            <a href="mailto:minnkotatackle@yahoo.com" class="transition-colors hover:text-white">
              minnkotatackle@yahoo.com
            </a>
          </li>
          <li class="pt-2">
            <a
              href="https://www.facebook.com/lqplakeassociation/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-lake-300 transition-colors hover:text-white"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Follow us on Facebook
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-lake-800 pt-8 text-center text-sm text-lake-400">
      <p>&copy; {currentYear} Lac Qui Parle Lake Association. All rights reserved.</p>
    </div>
  </div>
</footer>
