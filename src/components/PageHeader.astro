---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section style="background: #0F1B2D; padding-top: 120px;" class="pb-12">
  <div class="mx-auto max-w-[1000px] px-6 lg:px-12">
    <h1 class="font-display text-[38px] font-bold text-white sm:text-[44px]">{title}</h1>
    {subtitle && <p class="mt-3 max-w-xl text-lg text-white/50">{subtitle}</p>}
  </div>
</section>
