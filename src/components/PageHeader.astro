---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-bark-deep pb-16 pt-[120px]" style="padding-top: 120px;">
  <div class="mx-auto max-w-[1000px] px-6 lg:px-12">
    <h1 class="font-display text-[38px] font-bold text-wheat-pale sm:text-[44px]">{title}</h1>
    {subtitle && <p class="mt-3 max-w-xl text-lg text-wheat/60">{subtitle}</p>}
  </div>
</section>
<div class="blend-hero-to-content" style="height: 80px;"></div>
