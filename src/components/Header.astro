---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Tournament', href: '/tournament' },
  { label: 'League', href: '/fishing-league' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Membership', href: '/membership' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 flex h-[72px] items-center justify-between border-b border-white/[0.06] px-6 lg:px-12" style="background: rgba(15,27,45,0.9); backdrop-filter: blur(16px);">
  <a href="/" class="flex items-center gap-3 no-underline">
    <div class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-teal font-display text-sm font-bold text-white">
      LQP
    </div>
    <div class="hidden sm:block">
      <div class="font-display text-[17px] font-bold leading-tight text-white">Lac Qui Parle</div>
      <div class="font-body text-[9px] font-medium uppercase tracking-[2px] text-teal-light">Lake Association</div>
    </div>
  </a>

  <nav class="hidden lg:flex lg:gap-1">
    {navItems.map(item => (
      <a
        href={item.href}
        class:list={[
          'rounded-md px-3 py-[7px] text-xs font-medium transition-all',
          currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
            ? 'bg-white/[0.08] text-white'
            : 'text-white/50 hover:bg-white/[0.06] hover:text-white',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>

  <button
    id="mobile-menu-btn"
    class="inline-flex items-center justify-center rounded-lg p-2 text-white/60 transition-colors hover:bg-white/[0.06] lg:hidden"
    aria-label="Toggle menu"
  >
    <svg id="menu-open-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
    </svg>
    <svg id="menu-close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</header>

<div id="mobile-menu" class="fixed inset-x-0 top-[72px] z-40 hidden border-b border-white/[0.06] px-6 pb-4 pt-2 lg:hidden" style="background: rgba(15,27,45,0.95); backdrop-filter: blur(16px);">
  {navItems.map(item => (
    <a
      href={item.href}
      class:list={[
        'block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
        currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
          ? 'bg-white/[0.08] text-white'
          : 'text-white/50 hover:bg-white/[0.06] hover:text-white',
      ]}
    >
      {item.label}
    </a>
  ))}
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });
</script>
